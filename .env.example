FMP_API_KEY=你的_FMP_API_KEY

# 可选：AI 证据复核 / 手工复核助手
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-flash
QWEN_SECOND_MODEL=qwen-plus
QWEN_TIMEOUT_SECONDS=30
QWEN_MAX_RETRIES=2

# 可选：OpenAI / DashScope 复核 provider
OPENAI_API_KEY=
OPENAI_REVIEW_MODEL=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
AI_REVIEW_PROVIDER=

# 可选：盘后参考价 provider
POLYGON_API_KEY=
MASSIVE_API_KEY=
ALPHAVANTAGE_API_KEY=
# 可选：Alpaca P0 周五盘后 1m 数据源；留空时自动尝试 sip,boats,iex。
ALPACA_AFTERHOURS_FEED=

# 可选：Binance 网络诊断 / 替代 endpoint
BINANCE_USDM_BASE_URL=
BINANCE_SPOT_BASE_URL=
BINANCE_SPOT_DATA_BASE_URL=

# Optional: weekend spread P2 overnight price provider.
# ALPACA_BOATS uses Alpaca BOATS delayed historical 1m bars for backtest.
# For Free Plan, retry after the BOATS historical delay window when testing recent Sunday 20:00 ET bars.
# IBKR_OVERNIGHT reads local exported 1m bars from JSON.
OVERNIGHT_PRICE_PROVIDER=
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
IBKR_OVERNIGHT_BARS_PATH=

# Optional: TradingView alert webhook for weekend-spread P0/P2 local cache.
TRADINGVIEW_WEBHOOK_SECRET=
